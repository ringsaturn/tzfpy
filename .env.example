# Python configuration for building
# Uncomment and modify these variables based on your system setup


# For failed msg like: "dyld[92027]: Library not loaded: /install/lib/libpython3.12.dylib"

# For macOS with Homebrew Python
#PYTHON_CONFIGURE_OPTS=--enable-framework
#LIBRARY_PATH=/opt/homebrew/opt/python@3.12/Frameworks/Python.framework/Versions/3.12/lib

# For Linux
#LIBRARY_PATH=/usr/lib/python3.12

# For Windows (MSYS2/MinGW)
#LIBRARY_PATH=/mingw64/lib/python3.12
